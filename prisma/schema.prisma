// Das hier MUSS immer "prisma-client-js" bleiben
generator client {
  provider = "prisma-client-js"
}

// Das hier ist die echte Datenbank-Engine (die haben wir jetzt auf postgresql geändert)
datasource db {
  provider = "postgresql"
}

// Unsere Tabelle bleibt exakt gleich!
model CommandStat {
  name      String   @id
  uses      Int      @default(0)
  updatedAt DateTime @updatedAt
}